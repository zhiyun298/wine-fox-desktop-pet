{
	"name": "wine-fox",
	"version": "1.0.0",
	"description": "щЕТчЛРцбМхоа",
	"license": "MIT",
	"main": "electron/main.cjs",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"electron": "electron .",
		"app": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
		"app:build": "vite build && electron .",
		"dist": "vite build && electron-builder --win"
	},
	"dependencies": {
		"three": "^0.177.0",
		"wine-fox": "^0.2.1"
	},
	"devDependencies": {
		"concurrently": "^10.0.3",
		"electron": "^43.0.0",
		"electron-builder": "^25.1.8",
		"vite": "^8.1.3",
		"wait-on": "^9.0.10"
	},
	"build": {
		"appId": "com.winefox.desktop",
		"productName": "щЕТчЛР",
		"directories": {
			"output": "release"
		},
		"files": [
			"dist/**/*",
			"electron/**/*",
			"images/**/*",
			"package.json",
			"LICENSE",
			"THIRD-PARTY-NOTICES.md"
		],
		"win": {
			"target": [
				"nsis",
				"portable"
			]
		},
		"nsis": {
			"artifactName": "wine-fox-setup-${version}.${ext}",
			"oneClick": false,
			"perMachine": false,
			"allowToChangeInstallationDirectory": true,
			"createDesktopShortcut": true,
			"createStartMenuShortcut": true,
			"shortcutName": "щЕТчЛР"
		},
		"portable": {
			"artifactName": "wine-fox-portable-${version}.${ext}"
		}
	}
}
